# ══════════════════════════════════════════════════════
# GT BOT MVP — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to git
# ══════════════════════════════════════════════════════

# ── WHATSAPP CLOUD API ────────────────────────────────
# From: Meta for Developers → Your App → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=          # e.g. 123456789012345
WA_ACCESS_TOKEN=             # Permanent access token (starts with EAAG...)
WA_APP_SECRET=               # App Secret from App Settings → Basic
WA_WEBHOOK_VERIFY_TOKEN=     # Any string you invent (e.g. gt_bot_2026_secret)

# ── ANTHROPIC (CLAUDE) ────────────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=           # sk-ant-...

# ── SUPABASE ──────────────────────────────────────────
# From: supabase.com → Project → Settings → API
SUPABASE_URL=                # https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # service_role key (keep secret)

# ── GT WEBSITE API ────────────────────────────────────
GT_API_URL=https://grupoterranovasv.com/api
GT_API_SECRET=               # Secret header value to authenticate GT API calls
