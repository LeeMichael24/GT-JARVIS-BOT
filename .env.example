# ══════════════════════════════════════════════════════
# GT BOT MVP — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to git
# ══════════════════════════════════════════════════════

# ── WHATSAPP CLOUD API ────────────────────────────────
# From: Meta for Developers → Your App → WhatsApp → API Setup
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_permanent_access_token
WA_APP_SECRET=your_app_secret
WA_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# ── OPENAI ────────────────────────────────────────────
# From: platform.openai.com → API Keys
OPENAI_API_KEY=sk-your-openai-api-key

# ── SUPABASE ──────────────────────────────────────────
# From: supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── GT WEBSITE API ────────────────────────────────────
GT_API_URL=https://api.grupoterranovasv.com/api
GT_API_SECRET=your_gt_api_secret

# ── CEO PHONE NUMBER ─────────────────────────────────
CEO_PHONE_NUMBER=+503XXXXXXXX
